## Optional performance settings
## If preview is not reliably updating when content is changed, set PREVIEW_DELAY to 750-1000 ms
# PREVIEW_DELAY=750

## External Preview
## Set to true and add a token to enable external preview link functionality
# EXTERNAL_PREVIEW_ENABLED=false
# EXTERNAL_PREVIEW_TOKEN=OptiPreview123

## Development Mode
## Set to true to show GraphQL query debug panel in footer during development
OPTIMIZELY_DEV_MODE=false

## Admin Dashboard Authentication
## HTTP Basic Authentication credentials for /admin route
## If not configured, the admin dashboard will return 404
# ADMIN_DASHBOARD_USERNAME=admin
# ADMIN_DASHBOARD_PASSWORD=your-secure-password-here

## Optimizely Feature Experimentation SDK
## Required for A/B testing and content variants
# OPTIMIZELY_FX_SDK_KEY=your-fx-sdk-key-here

## Sitemap Configuration
## Base URL for absolute URLs in sitemap.xml
## If not set, uses the request origin (e.g., https://localhost:4321)
## Set this in production to ensure consistent URLs across environments
# SITEMAP_BASE_URL=https://example.com
